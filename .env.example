# PN Master Suite — environment template.
# Copy to `.env.local` (gitignored) and fill with PN's OWN Supabase project
# values (independent org — never RHS infra). Provided by Vicky at gate-1.
#
# Public (browser-safe; ship in client bundle):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PN-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PN-ANON-KEY

# Server-only (NEVER expose to the browser; used by the admin client behind
# 'server-only' + canPerformAction — OP MODEL §10):
SUPABASE_SERVICE_ROLE_KEY=YOUR-PN-SERVICE-ROLE-KEY
